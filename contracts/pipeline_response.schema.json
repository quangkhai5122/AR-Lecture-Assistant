{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PipelineResponse",
  "type": "object",
  "required": [
    "frame_id",
    "image_width",
    "image_height",
    "document_surface",
    "blocks",
    "provider",
    "mock_used",
    "warnings",
    "latency_ms"
  ],
  "properties": {
    "frame_id": { "type": "string" },
    "image_width": { "type": "integer" },
    "image_height": { "type": "integer" },
    "document_surface": {
      "type": ["object", "null"],
      "required": ["corners", "confidence", "method", "source"],
      "properties": {
        "corners": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": { "type": "number" },
          "description": "Four image-space corners: top-left, top-right, bottom-right, bottom-left."
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "method": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source_text", "translated_text", "bbox", "confidence", "type"],
        "properties": {
          "id": { "type": "string" },
          "source_text": { "type": "string" },
          "translated_text": { "type": "string" },
          "bbox": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": { "type": "number" },
            "description": "[x1, y1, x2, y2], origin top-left, in image pixel coordinates"
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "type": { "type": "string", "enum": ["text", "formula", "mixed"] },
          "style": {
            "type": "object",
            "properties": {
              "font_size": { "type": "integer" },
              "background_alpha": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        }
      }
    },
    "provider": {
        "type": "object",
        "required": ["ocr", "translation"],
        "properties": {
        "ocr": { "type": "string" },
        "translation": { "type": "string" }
      }
    },
    "mock_used": { "type": "boolean" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "latency_ms": {
      "type": "object",
      "required": ["surface_detection", "ocr", "translation", "total"],
      "properties": {
        "surface_detection": { "type": "number", "minimum": 0 },
        "ocr": { "type": "number", "minimum": 0 },
        "translation": { "type": "number", "minimum": 0 },
        "total": { "type": "number", "minimum": 0 }
      }
    }
  }
}
