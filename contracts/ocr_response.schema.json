{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OCRResponse",
  "type": "object",
  "required": ["image_width", "image_height", "blocks", "provider", "mock_used", "warnings"],
  "properties": {
    "image_width": { "type": "integer", "minimum": 1 },
    "image_height": { "type": "integer", "minimum": 1 },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "bbox", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "bbox": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": { "type": "number" },
            "description": "[x1, y1, x2, y2], origin top-left, in image pixel coordinates"
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "provider": {
      "type": "object",
      "required": ["ocr"],
      "properties": {
        "ocr": { "type": "string" }
      }
    },
    "mock_used": { "type": "boolean" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
