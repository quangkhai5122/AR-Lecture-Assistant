# Copy thành .env nếu cần. Không commit file .env thật.

# Nếu dùng LibreTranslate self-host hoặc public instance:
# LIBRETRANSLATE_URL=http://localhost:5001/translate
# LIBRETRANSLATE_API_KEY=

# OCR thật local nhẹ nhất cho demo macOS/Windows/Linux.
# macOS Homebrew: brew install tesseract
OCR_PROVIDER=tesseract
OCR_MIN_CONFIDENCE=0.2
TESSERACT_CMD=/opt/homebrew/bin/tesseract

# Dịch thật bằng Google Cloud Translation.
TRANSLATION_PROVIDER=google
GOOGLE_TRANSLATE_API_KEY=<your-google-translate-api-key>
GOOGLE_TRANSLATE_SOURCE_LANGUAGE=en
GOOGLE_TRANSLATE_TIMEOUT_SECONDS=20
