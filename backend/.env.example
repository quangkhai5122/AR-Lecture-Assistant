# Flask
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=1

# OCR
OCR_PROVIDER=tesseract
OCR_MIN_CONFIDENCE=0.22
OCR_ENABLE_PROVIDER_FALLBACK=1
OCR_FALLBACK_PROVIDER=tesseract
OCR_ALLOW_MOCK_FALLBACK=0
# Set this if tesseract is not on PATH.
# Example on Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=

# OCR preprocessing
OCR_PREPROCESS_ENABLED=1
OCR_UPSCALE_LONG_SIDE=3200
OCR_MAX_UPSCALE=4.0
OCR_GRAYSCALE=1
OCR_AUTOCONTRAST=1
OCR_AUTOCONTRAST_CUTOFF=1.0
OCR_CONTRAST=1.35
OCR_SHARPNESS=1.45
OCR_UNSHARP_MASK=1

# PaddleOCR (optional; install separately)
PADDLEOCR_LANG=en
PADDLEOCR_USE_GPU=1
PADDLEOCR_DEVICE=gpu

# Translation
TRANSLATION_PROVIDER=mock
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_TRANSLATE_SOURCE_LANGUAGE=en

# Speech
SPEECH_PROVIDER=google
GOOGLE_SPEECH_API_KEY=
GOOGLE_CLOUD_SPEECH_API_KEY=
# Alternatively set GOOGLE_APPLICATION_CREDENTIALS outside this file.

# Gemini
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TEMPERATURE=0.2
